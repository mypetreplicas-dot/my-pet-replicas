{{> header title="Verify Your Email Address" }}

<mj-section background-color="#0c0c0e" padding="30px 40px">
    <mj-column>
        <mj-text color="#d4d4d8" font-size="15px">
            Thank you for creating an account. Click the button below to verify this email address and
            complete the registration process:
        </mj-text>

        <mj-button font-family="'Outfit', 'Helvetica Neue', Arial, sans-serif"
                   background-color="#d4703e"
                   color="white"
                   font-size="14px"
                   font-weight="600"
                   border-radius="8px"
                   padding="12px 32px"
                   href="{{ verifyEmailAddressUrl }}?token={{ verificationToken }}">
            Verify My Email
        </mj-button>
    </mj-column>
</mj-section>

{{> footer }}
